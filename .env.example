# =============================================================================
# Variables de entorno para docker-compose (copia a .env y ajusta)
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=asistencia
POSTGRES_PASSWORD=asistencia_pwd
POSTGRES_DB=asistencia
POSTGRES_PORT=5432

# --- JWT / Auth ---
# Genera uno largo y aleatorio para producción, p.ej.:  openssl rand -hex 32
JWT_SECRET=cambia_esto_en_produccion_por_un_secreto_largo
COOKIE_SECURE=false            # true en producción (requiere HTTPS)

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
