# Variables de entorno del backend (copia a .env).
# En Docker estas son sobreescritas por docker-compose.yml.

# Base de datos
DATABASE_URL=postgresql+psycopg2://asistencia:asistencia_pwd@localhost:5432/asistencia

# JWT
JWT_SECRET=cambia_esto_en_produccion_por_un_secreto_largo
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
COOKIE_SECURE=false

# CORS (origen del frontend; pueden ir varios separados por coma)
FRONTEND_ORIGIN=http://localhost:3000

# Reglas de negocio (sección 7)
ACTIVE_SESSION_WINDOW_MIN=20
LAST_TYPE_MEMORY_HOURS=10

# Ejecutar seed al arrancar (dev)
RUN_SEED=true
